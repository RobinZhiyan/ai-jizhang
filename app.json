{
  "expo": {
    "name": "AI记账",
    "slug": "ai-jizhang",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#E4E5EA"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shengji.aijizhang"
    },
    "android": {
      "package": "com.shengji.aijizhang",
      "permissions": ["android.permission.RECORD_AUDIO"]
    },
    "newArchEnabled": false,
    "plugins": [
      [
        "@react-native-voice/voice",
        {
          "microphonePermission": "允许「AI记账」使用麦克风进行语音记账",
          "speechRecognitionPermission": "允许「AI记账」使用语音识别，按你说的话自动记账"
        }
      ]
    ]
  }
}
